<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CyberLens - Ciberseguridad</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- Navegacion -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="#" class="logo">
        <div class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        </div>
        <span>CyberLens</span>
      </a>
      <ul class="nav-links">
        <li><a href="#inicio">Inicio</a></li>
        <li><a href="#scanner">Scanner</a></li>
        <li><a href="#caracteristicas">Caracteristicas</a></li>
        <li><a href="#tecnologias">Tecnologias</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="inicio" class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <span class="badge">
        <span class="badge-dot"></span>
        Proyecto de Ciberseguridad
      </span>
      <h1 class="hero-title">Cyber<span class="gradient-text">Lens</span></h1>
      <p class="hero-subtitle">Mapea, Analiza y Protege tu Superficie de Ataque en tiempo real</p>
      <p class="hero-description">
        Herramienta avanzada de reconocimiento web, deteccion de vulnerabilidades 
        y gestion de superficie de ataque para profesionales de ciberseguridad.
      </p>
      <div class="hero-buttons">
        <a href="#scanner" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Iniciar Escaneo
        </a>
        <a href="#caracteristicas" class="btn btn-secondary">
          Conocer Mas
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number">500+</span>
          <span class="stat-label">Escaneos</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">50+</span>
          <span class="stat-label">Vulnerabilidades</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">99%</span>
          <span class="stat-label">Precision</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Scanner Section -->
  <section id="scanner" class="scanner-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Simulador</span>
        <h2 class="section-title">Centro de <span class="gradient-text">Reconocimiento</span></h2>
        <p class="section-description">Ingresa un dominio y observa el proceso de analisis en tiempo real</p>
      </div>

      <div class="scanner-container">
        <!-- Input Panel -->
        <div class="scanner-input-panel">
          <div class="input-group">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <input type="text" class="domain-input" placeholder="ejemplo.com" value="cyberlens.com">
          </div>
          <button class="scan-button">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Iniciar Reconocimiento
          </button>
        </div>

        <!-- Terminal -->
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <span class="terminal-title">CyberLens Terminal v2.0</span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line">
              <span class="prompt">$</span>
              <span class="command">cyberlens --target cyberlens.com --full-scan</span>
            </div>
            <div class="terminal-line delay-1">
              <span class="output info">[*] Iniciando reconocimiento de superficie de ataque...</span>
            </div>
            <div class="terminal-line delay-2">
              <span class="output info">[*] Objetivo: cyberlens.com</span>
            </div>
            <div class="terminal-line delay-3">
              <span class="output warning">[!] Fase 1: Enumeracion de subdominios</span>
            </div>
            <div class="terminal-line delay-4">
              <span class="output success">[+] Encontrado: api.cyberlens.com</span>
            </div>
            <div class="terminal-line delay-5">
              <span class="output success">[+] Encontrado: dev.cyberlens.com</span>
            </div>
            <div class="terminal-line delay-6">
              <span class="output success">[+] Encontrado: admin.cyberlens.com</span>
            </div>
            <div class="terminal-line delay-7">
              <span class="output success">[+] Encontrado: staging.cyberlens.com</span>
            </div>
            <div class="terminal-line delay-8">
              <span class="output warning">[!] Fase 2: Escaneo de puertos</span>
            </div>
            <div class="terminal-line delay-9">
              <span class="output success">[+] Puerto 80/tcp - HTTP (abierto)</span>
            </div>
            <div class="terminal-line delay-10">
              <span class="output success">[+] Puerto 443/tcp - HTTPS (abierto)</span>
            </div>
            <div class="terminal-line delay-11">
              <span class="output success">[+] Puerto 22/tcp - SSH (abierto)</span>
            </div>
            <div class="terminal-line delay-12">
              <span class="output success">[+] Puerto 3306/tcp - MySQL (abierto)</span>
            </div>
            <div class="terminal-line delay-13">
              <span class="output warning">[!] Fase 3: Deteccion de vulnerabilidades</span>
            </div>
            <div class="terminal-line delay-14">
              <span class="output error">[!] CRITICO: SQL Injection en /api/users</span>
            </div>
            <div class="terminal-line delay-15">
              <span class="output error">[!] ALTO: XSS Reflejado en /search</span>
            </div>
            <div class="terminal-line delay-16">
              <span class="output warning">[!] MEDIO: Headers de seguridad faltantes</span>
            </div>
            <div class="terminal-line delay-17">
              <span class="output info">[*] Escaneo completado en 12.4 segundos</span>
            </div>
            <div class="terminal-line delay-18">
              <span class="output success">[+] Reporte generado exitosamente</span>
            </div>
            <div class="terminal-line cursor delay-19">
              <span class="prompt">$</span>
              <span class="cursor-blink">_</span>
            </div>
          </div>
        </div>

        <!-- Results Dashboard -->
        <div class="results-dashboard">
          <h3 class="results-title">Resultados del Analisis</h3>
          <div class="results-grid">
            <!-- Subdominios -->
            <div class="result-card">
              <div class="result-header">
                <div class="result-icon blue">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div class="result-info">
                  <span class="result-label">Subdominios</span>
                  <span class="result-count blue">4 encontrados</span>
                </div>
              </div>
              <ul class="result-list">
                <li><span class="dot-indicator blue"></span>api.cyberlens.com</li>
                <li><span class="dot-indicator blue"></span>dev.cyberlens.com</li>
                <li><span class="dot-indicator blue"></span>admin.cyberlens.com</li>
                <li><span class="dot-indicator blue"></span>staging.cyberlens.com</li>
              </ul>
            </div>

            <!-- Puertos -->
            <div class="result-card">
              <div class="result-header">
                <div class="result-icon green">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                </div>
                <div class="result-info">
                  <span class="result-label">Puertos Abiertos</span>
                  <span class="result-count green">4 detectados</span>
                </div>
              </div>
              <ul class="result-list">
                <li><span class="dot-indicator green"></span>80/tcp - HTTP</li>
                <li><span class="dot-indicator green"></span>443/tcp - HTTPS</li>
                <li><span class="dot-indicator green"></span>22/tcp - SSH</li>
                <li><span class="dot-indicator green"></span>3306/tcp - MySQL</li>
              </ul>
            </div>

            <!-- Vulnerabilidades -->
            <div class="result-card">
              <div class="result-header">
                <div class="result-icon red">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div class="result-info">
                  <span class="result-label">Vulnerabilidades</span>
                  <span class="result-count red">3 detectadas</span>
                </div>
              </div>
              <ul class="result-list">
                <li><span class="severity critical">CRITICO</span>SQL Injection</li>
                <li><span class="severity high">ALTO</span>XSS Reflejado</li>
                <li><span class="severity medium">MEDIO</span>Headers faltantes</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Caracteristicas Section -->
  <section id="caracteristicas" class="features-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Funcionalidades</span>
        <h2 class="section-title">Caracteristicas <span class="gradient-text">Principales</span></h2>
        <p class="section-description">Herramientas avanzadas para el analisis completo de seguridad</p>
      </div>

      <div class="features-grid">
        <!-- Feature 1 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Web Reconnaissance</h3>
          <p class="feature-description">Enumeracion avanzada de subdominios, tecnologias web y puntos de entrada utilizando multiples fuentes de datos.</p>
          <div class="feature-tags">
            <span class="tag">Subdominios</span>
            <span class="tag">DNS</span>
            <span class="tag">OSINT</span>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Deteccion de Vulnerabilidades</h3>
          <p class="feature-description">Identificacion automatica de fallos de seguridad como SQL Injection, XSS, CSRF y configuraciones inseguras.</p>
          <div class="feature-tags">
            <span class="tag">SQLi</span>
            <span class="tag">XSS</span>
            <span class="tag">CSRF</span>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Monitoreo Continuo</h3>
          <p class="feature-description">Vigilancia 24/7 de tu superficie de ataque con alertas en tiempo real cuando se detectan cambios o nuevas amenazas.</p>
          <div class="feature-tags">
            <span class="tag">24/7</span>
            <span class="tag">Alertas</span>
            <span class="tag">Dashboard</span>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Automatizacion</h3>
          <p class="feature-description">Workflows automatizados para escaneos programados, generacion de reportes y notificaciones personalizadas.</p>
          <div class="feature-tags">
            <span class="tag">Workflows</span>
            <span class="tag">Reportes</span>
            <span class="tag">API</span>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Escaneo de Puertos</h3>
          <p class="feature-description">Deteccion de servicios expuestos, versiones de software y configuraciones de red potencialmente vulnerables.</p>
          <div class="feature-tags">
            <span class="tag">TCP/UDP</span>
            <span class="tag">Servicios</span>
            <span class="tag">Nmap</span>
          </div>
        </div>

        <!-- Feature 6 -->
        <div class="feature-card">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </div>
          </div>
          <h3 class="feature-title">Base de Datos Segura</h3>
          <p class="feature-description">Almacenamiento seguro de resultados con Supabase, historial de escaneos y comparativas de seguridad.</p>
          <div class="feature-tags">
            <span class="tag">Supabase</span>
            <span class="tag">Historial</span>
            <span class="tag">Cifrado</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tecnologias Section -->
  <section id="tecnologias" class="tech-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Stack</span>
        <h2 class="section-title">Tecnologias <span class="gradient-text">Utilizadas</span></h2>
        <p class="section-description">Construido con las mejores herramientas de desarrollo y ciberseguridad</p>
      </div>

      <div class="tech-grid">
        <div class="tech-card">
          <div class="tech-icon python">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05zm-6.3 1.98l-.23.33-.08.41.08.41.23.34.33.22.41.09.41-.09.33-.22.23-.34.08-.41-.08-.41-.23-.33-.33-.22-.41-.09-.41.09zm13.09 3.95l.28.06.32.12.35.18.36.27.36.35.35.47.32.59.28.73.21.88.14 1.04.05 1.23-.06 1.23-.16 1.04-.24.86-.32.71-.36.57-.4.45-.42.33-.42.24-.4.16-.36.09-.32.05-.24.02-.16-.01h-8.22v.82h5.84l.01 2.76.02.36-.05.34-.11.31-.17.29-.25.25-.31.24-.38.2-.44.17-.51.15-.58.13-.64.09-.71.07-.77.04-.84.01-1.27-.04-1.07-.14-.9-.2-.73-.25-.59-.3-.45-.33-.34-.34-.25-.34-.16-.33-.1-.3-.04-.25-.02-.2.01-.13v-5.34l.05-.64.13-.54.21-.46.26-.38.3-.32.33-.24.35-.2.35-.14.33-.1.3-.06.26-.04.21-.02.13-.01h5.84l.69-.05.59-.14.5-.21.41-.28.33-.32.27-.35.2-.36.15-.36.1-.35.07-.32.04-.28.02-.21V6.07h2.09l.14.01zm-6.47 14.25l-.23.33-.08.41.08.41.23.33.33.23.41.08.41-.08.33-.23.23-.33.08-.41-.08-.41-.23-.33-.33-.23-.41-.08-.41.08z"/></svg>
          </div>
          <span class="tech-name">Python</span>
        </div>

        <div class="tech-card">
          <div class="tech-icon supabase">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.9 1.036c-.015-.986-1.26-1.41-1.874-.637L.764 12.05C-.33 13.427.65 15.455 2.409 15.455h9.579l.113 7.51c.014.985 1.259 1.408 1.873.636l9.262-11.653c1.093-1.375.113-3.403-1.645-3.403h-9.642z"/></svg>
          </div>
          <span class="tech-name">Supabase</span>
        </div>

        <div class="tech-card">
          <div class="tech-icon react">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.23 12.004a2.236 2.236 0 0 1-2.235 2.236 2.236 2.236 0 0 1-2.236-2.236 2.236 2.236 0 0 1 2.235-2.236 2.236 2.236 0 0 1 2.236 2.236zm2.648-10.69c-1.346 0-3.107.96-4.888 2.622-1.78-1.653-3.542-2.602-4.887-2.602-.41 0-.783.093-1.106.278-1.375.793-1.683 3.264-.973 6.365C1.98 8.917 0 10.42 0 12.004c0 1.59 1.99 3.097 5.043 4.03-.704 3.113-.39 5.588.988 6.38.32.187.69.275 1.102.275 1.345 0 3.107-.96 4.888-2.624 1.78 1.654 3.542 2.603 4.887 2.603.41 0 .783-.09 1.106-.275 1.374-.792 1.683-3.263.973-6.365C22.02 15.096 24 13.59 24 12.004c0-1.59-1.99-3.097-5.043-4.032.704-3.11.39-5.587-.988-6.38-.318-.184-.688-.277-1.092-.278zm-.005 1.09v.006c.225 0 .406.044.558.127.666.382.955 1.835.73 3.704-.054.46-.142.945-.25 1.44-.96-.236-2.006-.417-3.107-.534-.66-.905-1.345-1.727-2.035-2.447 1.592-1.48 3.087-2.292 4.105-2.295zm-9.77.02c1.012 0 2.514.808 4.11 2.28-.686.72-1.37 1.537-2.02 2.442-1.107.117-2.154.298-3.113.538-.112-.49-.195-.964-.254-1.42-.23-1.868.054-3.32.714-3.707.19-.09.4-.127.563-.132zm4.882 3.05c.455.468.91.992 1.36 1.564-.44-.02-.89-.034-1.345-.034-.46 0-.915.01-1.36.034.44-.572.895-1.096 1.345-1.565zM12 8.1c.74 0 1.477.034 2.202.093.406.582.802 1.203 1.183 1.86.372.64.71 1.29 1.018 1.946-.308.655-.646 1.31-1.013 1.95-.38.66-.773 1.288-1.18 1.87-.728.063-1.466.098-2.21.098-.74 0-1.477-.035-2.202-.093-.406-.582-.802-1.204-1.183-1.86-.372-.64-.71-1.29-1.018-1.946.303-.657.646-1.313 1.013-1.954.38-.66.773-1.286 1.18-1.868.728-.064 1.466-.098 2.21-.098zm-3.635.254c-.24.377-.48.763-.704 1.16-.225.39-.435.782-.635 1.174-.265-.656-.49-1.31-.676-1.947.64-.15 1.315-.283 2.015-.386zm7.26 0c.695.103 1.365.23 2.006.387-.18.632-.405 1.282-.66 1.933-.2-.39-.41-.783-.64-1.174-.225-.392-.465-.774-.705-1.146zm3.063.675c.484.15.944.317 1.375.498 1.732.74 2.852 1.708 2.852 2.476-.005.768-1.125 1.74-2.857 2.475-.42.18-.88.342-1.355.493-.28-.958-.646-1.956-1.1-2.98.45-1.017.81-2.01 1.085-2.964zm-13.395.004c.278.96.645 1.95