  <!-- Proceso Section -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">Metodologia</span>
        <h2 class="section-title">Como <span class="gradient-text">Funciona</span></h2>
        <p class="section-description">Proceso de analisis de seguridad en 4 pasos</p>
      </div>

      <div class="process-timeline">
        <div class="process-step">
          <div class="step-number">01</div>
          <div class="step-content">
            <h3>Ingreso de Objetivo</h3>
            <p>El usuario ingresa el dominio o IP a analizar en la interfaz de CyberLens.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-number">02</div>
          <div class="step-content">
            <h3>Reconocimiento</h3>
            <p>Se realiza enumeracion de subdominios, DNS y tecnologias web detectadas.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-number">03</div>
          <div class="step-content">
            <h3>Escaneo Activo</h3>
            <p>Analisis de puertos, servicios y busqueda automatizada de vulnerabilidades.</p>
          </div>
        </div>
        <div class="process-connector"></div>
        <div class="process-step">
          <div class="step-number">04</div>
          <div class="step-content">
            <h3>Reporte Final</h3>
            <p>Generacion de informe detallado con hallazgos y recomendaciones de seguridad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section id="contacto" class="cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-glow"></div>
        <div class="cta-content">
          <h2 class="cta-title">Protege tu Infraestructura</h2>
          <p class="cta-description">CyberLens te ayuda a identificar y mitigar vulnerabilidades antes de que los atacantes las exploten.</p>
          <a href="#scanner" class="btn btn-primary btn-large">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Probar Demo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <a href="#" class="logo">
            <div class="logo-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            </div>
            <span>CyberLens</span>
          </a>
          <p class="footer-tagline">Herramienta de ciberseguridad para reconocimiento web y deteccion de vulnerabilidades.</p>
        </div>
        <div class="footer-social">
          <a href="https://instagram.com/_brayanf0" target="_blank" rel="noopener noreferrer" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            <span>@_brayanf0</span>
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 CyberLens. Proyecto de Ciberseguridad.</p>
      </div>
    </div>
  </footer>

